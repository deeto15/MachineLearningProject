REDDIT_PASSWORD=

# RabbitMQ credentials (any values, used by both the broker and the services)
RABBITMQ_DEFAULT_USER=devuser
RABBITMQ_DEFAULT_PASS=devpassword

# Scraper settings
SUBREDDIT=wallstreetbets
POLL_FREQUENCY_SECONDS=15
POST_CUTOFF_MINUTES=1440
POST_DELETION_BUFFER_MINUTES=60
POST_DELETION_FREQUENCY_SECONDS=300
MAX_POSTS_PER_POLL=25
